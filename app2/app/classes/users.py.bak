    def create_intibak_table(self) -> OperationResult:
        """Create intibak table. Returns OperationResult."""
        return OperationResult.ok()

    def edit_course_match(self) -> OperationResult:
        """Edit course match. Returns OperationResult."""
        return OperationResult.ok()

    def save_intibak_table(self) -> OperationResult:
        """Save intibak table. Returns OperationResult."""
        return OperationResult.ok()


class Oidb(User, IReviewer, IDocumentHandler):
    """OIDB role."""

    def get_pending_applicants(self) -> list:
        """Get pending applications."""
        from ..models import Application
        from sqlalchemy.orm import selectinload

        return (
            Application.query.options(
                selectinload(Application.documents), selectinload(Application.applicant)
            )
            .order_by(Application.created_at.desc())
            .all()
        )

    def update_applicant_status(self, application_id: int, status: str) -> OperationResult:
        """Update application status. Returns OperationResult."""
        from .. import db
        from ..models import Application

        try:
            app = Application.query.get(application_id)
            if not app:
                return OperationResult.error(
                    ErrorCode.APPLICATION_NOT_FOUND,
                    f"Application {application_id} not found."
                )
            app.status = status
            db.session.commit()
            return OperationResult.ok(data=app)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to update status: {str(exc)}"
            )

    def forward_to_ydyo(self, application_id: int) -> OperationResult:
        """Forward application to YDYO. Returns OperationResult."""
        from .. import db
        from ..models import Application

        try:
            app = Application.query.get(application_id)
            if not app:
                return OperationResult.error(
                    ErrorCode.APPLICATION_NOT_FOUND,
                    f"Application {application_id} not found."
                )
            if app.status not in ("submitted", "returned"):
                return OperationResult.error(
                    ErrorCode.INVALID_STATUS_TRANSITION,
                    f"Cannot forward from status '{app.status}'."
                )
            app.status = "forwarded_to_ydyo"
            db.session.commit()
            return OperationResult.ok(data=app)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to forward application: {str(exc)}"
            )

    def forward_all_to_ydyo(self) -> OperationResult:
        """Forward all submitted applications to YDYO. Returns OperationResult."""
        from .. import db
        from ..models import Application

        try:
            apps = Application.query.filter_by(status="submitted").all()
            count = len(apps)
            for app in apps:
                app.status = "forwarded_to_ydyo"
            db.session.commit()
            return OperationResult.ok(data={"forwarded_count": count})
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to forward applications: {str(exc)}"
            )

    def return_application(self, application_id: int, notes: str) -> OperationResult:
        """Return application to applicant. Returns OperationResult."""
        from .. import db
        from ..models import Application

        if not notes or not notes.strip():
            return OperationResult.error(
                ErrorCode.MISSING_REQUIRED_FIELDS,
                "A reason is required when returning an application."
            )

        try:
            app = Application.query.get(application_id)
            if not app or app.status != "submitted":
                return OperationResult.error(
                    ErrorCode.INVALID_STATUS_TRANSITION,
                    "Cannot return this application."
                )
            app.status = "returned"
            app.oidb_notes = notes
            db.session.commit()
            return OperationResult.ok(data=app)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to return application: {str(exc)}"
            )

    def get_document(self, doc_id: int) -> OperationResult:
        """Get document. Returns OperationResult."""
        from ..models import ApplicationDocument

        try:
            doc = ApplicationDocument.query.get(doc_id)
            if not doc:
                return OperationResult.error(
                    ErrorCode.DOCUMENT_NOT_FOUND,
                    f"Document {doc_id} not found."
                )
            return OperationResult.ok(data=doc)
        except Exception as exc:
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to retrieve document: {str(exc)}"
            )

    def upload(self, payload: dict[str, Any]) -> OperationResult:
        """Upload document. Returns OperationResult."""
        if not payload:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "Payload cannot be empty."
            )
        return OperationResult.ok(data=payload)

    def validate(self, document_id: int) -> OperationResult:
        """Validate document. Returns OperationResult."""
        if document_id <= 0:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "Document ID must be positive."
            )
        return OperationResult.ok()

    def retrieve(self, applicant_id: int) -> OperationResult:
        """Retrieve applicant documents. Returns OperationResult."""
        return OperationResult.ok(data=self.get_pending_applicants())


class Ydyo(User, IReviewer):
    """YDYO role."""

    def get_pending_applicants(self) -> list:
        """Get pending applications."""
        return self.get_applications()

    def update_applicant_status(self, applicant_id: int, status: str) -> OperationResult:
        """Update applicant status. Returns OperationResult."""
        if applicant_id <= 0 or not status:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "Invalid applicant ID or status."
            )
        return OperationResult.ok()

    def get_applications(self) -> list:
        """Get applications forwarded to YDYO."""
        from ..models import Application
        from sqlalchemy.orm import selectinload

        return (
            Application.query.options(
                selectinload(Application.documents), selectinload(Application.applicant)
            )
            .filter_by(status="forwarded_to_ydyo")
            .order_by(Application.created_at.desc())
            .all()
        )

    def get_document(self, doc_id: int) -> OperationResult:
        """Get document. Returns OperationResult."""
        from ..models import ApplicationDocument

        try:
            doc = ApplicationDocument.query.get(doc_id)
            if not doc:
                return OperationResult.error(
                    ErrorCode.DOCUMENT_NOT_FOUND,
                    f"Document {doc_id} not found."
                )
            return OperationResult.ok(data=doc)
        except Exception as exc:
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to retrieve document: {str(exc)}"
            )

    _VALID_PREP_STATUSES = {"eligible", "needs_test"}

    def mark_and_forward(self, application_id: int, prep_status: str) -> OperationResult:
        """Set prep school status and forward to Dean. Returns OperationResult."""
        from .. import db
        from ..models import Application

        if prep_status not in self._VALID_PREP_STATUSES:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                f"Invalid prep school status. Must be one of {self._VALID_PREP_STATUSES}."
            )

        try:
            app = Application.query.get(application_id)
            if not app:
                return OperationResult.error(
                    ErrorCode.APPLICATION_NOT_FOUND,
                    f"Application {application_id} not found."
                )
            if app.status != "forwarded_to_ydyo":
                return OperationResult.error(
                    ErrorCode.INVALID_STATUS_TRANSITION,
                    f"Cannot process application in status '{app.status}'."
                )
            app.prep_school_status = prep_status
            app.status = "forwarded_to_dean"
            db.session.commit()
            label = "Eligible" if prep_status == "eligible" else "Needs Internal Test"
            return OperationResult.ok(data=app)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to process application: {str(exc)}"
            )

    def forward_all_to_dean(self) -> OperationResult:
        """Forward all applications to Dean. Returns OperationResult."""
        return OperationResult.error(
            ErrorCode.UNKNOWN_ERROR,
            "Auto-forward to Dean is not yet implemented."
        )

    def set_prepschool_status(self) -> OperationResult:
        """Set prep school status. Returns OperationResult."""
        return OperationResult.ok()

