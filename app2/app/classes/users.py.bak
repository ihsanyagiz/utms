"""Role-oriented domain user classes."""

from __future__ import annotations

from abc import ABC
from typing import Any

from ..core import OperationResult, ErrorCode
from .interfaces import IDocumentHandler, IReviewer


class User(ABC):
    """Abstract system user."""

    def __init__(self, user_id: int, email: str, role: str) -> None:
        self.user_id = user_id
        self.email = email
        self.role = role

    def get_id(self) -> int:
        return self.user_id


class Applicant(User, IDocumentHandler):
    """Applicant business role."""

    # --- IDocumentHandler interface ---

    def upload(self, payload: dict[str, Any]) -> OperationResult:
        """Upload documents. Returns OperationResult with upload status."""
        if not payload:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "Payload cannot be empty."
            )
        return OperationResult.ok(data=payload)

    def validate(self, document_id: int) -> OperationResult:
        """Validate document ID. Returns OperationResult."""
        if document_id <= 0:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "Document ID must be positive."
            )
        return OperationResult.ok()

    def retrieve(self, applicant_id: int) -> OperationResult:
        """Retrieve applicant documents. Returns OperationResult with document list."""
        # TODO: Implement document retrieval from database
        return OperationResult.ok(data=[])

    # --- Form helpers (static — no Flask context needed) ---

    @staticmethod
    def parse_form_data(form) -> dict:
        """Parse and normalize form data for application submission."""
        id_number = (form.get("id_number") or "").strip()
        target_program = (form.get("target_program") or "").strip()
        return {
            "full_name": (form.get("full_name") or "").strip(),
            "id_number": id_number,
            "student_number": id_number,
            "target_program": target_program,
            "target_department": target_program,
            "target_semester": (form.get("target_semester") or "").strip(),
            "current_gpa": (form.get("current_gpa") or "").strip(),
            "source_university": (form.get("source_university") or "").strip(),
            "is_currently_enrolled": True,
        }

    @staticmethod
    def validate_form_data(form_data: dict) -> OperationResult:
        """Validate application form data. Returns OperationResult."""
        required = ["full_name", "id_number", "target_program", "target_semester", "current_gpa", "source_university"]
        if not all(bool(form_data.get(k)) for k in required):
            return OperationResult.error(
                ErrorCode.MISSING_REQUIRED_FIELDS,
                "All required fields must be filled."
            )
        try:
            gpa = float(form_data["current_gpa"])
            if not (0.0 <= gpa <= 4.0):
                return OperationResult.error(
                    ErrorCode.GPA_OUT_OF_RANGE,
                    "GPA must be between 0.00 and 4.00."
                )
        except ValueError:
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "GPA must be a valid number (e.g. 3.50)."
            )
        return OperationResult.ok()

    # --- Document saving ---

    def save_documents(self, application_id: int, upload_root, files, document_slots) -> list:
        """Save uploaded documents to disk. Returns list of ApplicationDocument objects."""
        from pathlib import Path
        from werkzeug.utils import secure_filename
        from ..models import ApplicationDocument

        docs = []
        for slot_def in document_slots:
            slot = slot_def["slot"]
            label = slot_def["label"]
            file_item = files.get(f"document_{slot}")
            if file_item is None or file_item.filename == "":
                continue
            if not file_item.filename.lower().endswith(".pdf"):
                raise ValueError(f"{label} must be a PDF file.")
            safe_name = secure_filename(file_item.filename)
            stored_name = f"application_{application_id}_document_{slot}_{safe_name}"
            full_path = Path(upload_root) / stored_name
            file_item.save(full_path)
            docs.append(ApplicationDocument(
                application_id=application_id,
                document_slot=slot,
                original_name=safe_name,
                stored_name=stored_name,
                file_path=str(full_path),
            ))
        return docs

    # --- Application lifecycle ---

    def submit(
        self, form_data: dict, upload_root, files, document_slots
    ) -> OperationResult:
        """Submit new application. Returns OperationResult with created Application."""
        from pathlib import Path
        from sqlalchemy.exc import IntegrityError
        from .. import db
        from ..models import Application

        # Check if applicant already has an application
        if Application.query.filter_by(applicant_id=self.user_id).first() is not None:
            return OperationResult.error(
                ErrorCode.APPLICATION_EXISTS,
                "You already have an application."
            )
        try:
            application = Application(
                applicant_id=self.user_id, status="submitted", **form_data
            )
            db.session.add(application)
            db.session.flush()
            root = Path(upload_root)
            root.mkdir(parents=True, exist_ok=True)
            for doc in self.save_documents(application.id, root, files, document_slots):
                db.session.add(doc)
            db.session.commit()
            return OperationResult.ok(data=application)
        except ValueError as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.INVALID_FILE_FORMAT,
                str(exc)
            )
        except IntegrityError:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_INTEGRITY_ERROR,
                "Could not create application due to a data conflict."
            )
        except OSError:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.FILE_NOT_SAVED,
                "Could not store uploaded files."
            )

    def resubmit(
        self, application, form_data: dict, upload_root, files, document_slots
    ) -> OperationResult:
        """Resubmit application. Returns OperationResult."""
        from pathlib import Path
        from .. import db

        try:
            for field, value in form_data.items():
                setattr(application, field, value)
            application.status = "submitted"
            application.oidb_notes = None
            for old_doc in list(application.documents):
                db.session.delete(old_doc)
            db.session.flush()
            root = Path(upload_root)
            root.mkdir(parents=True, exist_ok=True)
            for doc in self.save_documents(application.id, root, files, document_slots):
                db.session.add(doc)
            db.session.commit()
            return OperationResult.ok(data=application)
        except ValueError as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.INVALID_FILE_FORMAT,
                str(exc)
            )
        except OSError:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.FILE_NOT_SAVED,
                "Could not store uploaded files."
            )

    def cancel(self, application) -> OperationResult:
        """Cancel application. Returns OperationResult."""
        from .. import db

        try:
            application.status = "cancelled"
            db.session.commit()
            return OperationResult.ok(data=application)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to cancel application: {str(exc)}"
            )

    def resubmit(
        self, application, form_data: dict, upload_root, files, document_slots
    ) -> OperationResult:
        """Resubmit application. Returns OperationResult."""
        from pathlib import Path
        from .. import db

        try:
            for field, value in form_data.items():
                setattr(application, field, value)
            application.status = "submitted"
            application.oidb_notes = None
            for old_doc in list(application.documents):
                db.session.delete(old_doc)
            db.session.flush()
            root = Path(upload_root)
            root.mkdir(parents=True, exist_ok=True)
            for doc in self.save_documents(application.id, root, files, document_slots):
                db.session.add(doc)
            db.session.commit()
            return OperationResult.ok(data=application)
        except ValueError as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.INVALID_FILE_FORMAT,
                str(exc)
            )
        except OSError:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.FILE_NOT_SAVED,
                "Could not store uploaded files."
            )

    def cancel(self, application) -> OperationResult:
        """Cancel application. Returns OperationResult."""
        from .. import db

        try:
            application.status = "cancelled"
            db.session.commit()
            return OperationResult.ok(data=application)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to cancel application: {str(exc)}"
            )


class DeanOffice(User, IReviewer):
    """Dean office reviewer."""

    def get_pending_applicants(self) -> list:
        """Get pending applications for dean review."""
        from ..models import Application
        from sqlalchemy.orm import selectinload
        return (
            Application.query
            .options(selectinload(Application.documents), selectinload(Application.applicant))
            .filter(Application.status.in_(["forwarded_to_dean", "forwarded_to_ygk"]))
            .order_by(Application.created_at.desc())
            .all()
        )

    def update_applicant_status(self, application_id: int, status: str) -> OperationResult:
        """Update application status. Returns OperationResult."""
        from .. import db
        from ..models import Application

        try:
            app = Application.query.get(application_id)
            if not app:
                return OperationResult.error(
                    ErrorCode.APPLICATION_NOT_FOUND,
                    f"Application {application_id} not found."
                )
            app.status = status
            db.session.commit()
            return OperationResult.ok(data=app)
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to update application status: {str(exc)}"
            )

    def forward_to_ygk(self, application_id: int, faculty: str) -> OperationResult:
        """Forward application to YGK. Returns OperationResult."""
        from .. import db
        from ..models import Application

        if not faculty or not faculty.strip():
            return OperationResult.error(
                ErrorCode.VALIDATION_FAILED,
                "A faculty must be selected before forwarding."
            )
        try:
            app = Application.query.get(application_id)
            if not app:
                return OperationResult.error(
                    ErrorCode.APPLICATION_NOT_FOUND,
                    f"Application {application_id} not found."
                )
            if app.status != "forwarded_to_dean":
                return OperationResult.error(
                    ErrorCode.INVALID_STATUS_TRANSITION,
                    f"Cannot forward application in status '{app.status}'."
                )
            app.forwarded_faculty = faculty
            app.status = "forwarded_to_ygk"
            db.session.commit()
            return OperationResult.ok(
                data=app,
            )
        except Exception as exc:
            db.session.rollback()
            return OperationResult.error(
                ErrorCode.DB_ERROR,
                f"Failed to forward application: {str(exc)}"
            )

    def forward_all_to_ygk(self) -> OperationResult:
        """Forward all pending applications to YGK. Returns OperationResult."""
        return OperationResult.error(
            ErrorCode.UNKNOWN_ERROR,
            "Auto-forward to YGK is not yet implemented."
        )


class YGK(User, IReviewer):
    """YGK reviewer."""

    def get_pending_applicants(self) -> list:
